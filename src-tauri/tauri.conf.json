{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Reki",
  "version": "0.1.0",
  "identifier": "at.outlook.zhichao.reki",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Reki 歴",
        "width": 1100,
        "height": 720,
        "minWidth": 680,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/media/*", "$APPDATA/media/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Modern spaced repetition",
    "longDescription": "Reki 歴 — A modern Anki replacement built with Tauri, Svelte 5, and Rust."
  }
}
